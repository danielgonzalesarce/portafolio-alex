rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "daniel.gonzales.a@tecsup.edu.pe" || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             (!('role' in data) || data.role in ['user', 'admin']);
    }

    function isValidAcquisition(data) {
      return data.keys().hasAll(['userId', 'projectId', 'acquiredAt']) &&
             data.userId is string &&
             data.projectId is string &&
             data.acquiredAt is timestamp;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['userId', 'userName', 'rating', 'comment', 'createdAt']) &&
             data.userId is string &&
             data.userName is string &&
             data.rating is number &&
             data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() < 1000 &&
             data.createdAt is timestamp;
    }

    function isValidBriefing(data) {
      return data.keys().hasAll(['agentName', 'email', 'objective', 'details', 'createdAt']) &&
             data.agentName is string && data.agentName.size() < 100 &&
             data.email is string && data.email.matches('^.+@.+\\..+$') &&
             data.objective is string &&
             data.details is string && data.details.size() < 5000 &&
             data.createdAt is timestamp;
    }

    function isValidSupportMessage(data) {
      return data.keys().hasAll(['name', 'email', 'subject', 'message', 'createdAt']) &&
             data.name is string &&
             data.email is string &&
             data.subject is string &&
             data.message is string &&
             data.createdAt is timestamp;
    }

    function isValidProject(data) {
      return data.keys().hasAll(['name', 'category', 'thumbnail']) &&
             data.name is string &&
             data.category is string &&
             data.thumbnail is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /briefings/{briefingId} {
      allow read: if isAdmin();
      allow create: if isValidBriefing(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /support_messages/{messageId} {
      allow read: if isAdmin();
      allow create: if isValidSupportMessage(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true; // Reviews are public
      allow create: if isAuthenticated() && 
                    request.resource.data.userId == request.auth.uid && 
                    isValidReview(request.resource.data);
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (!('role' in request.resource.data) || request.resource.data.role == 'user' || isAdmin());
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) &&
                    (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /acquisitions/{acquisitionId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidAcquisition(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /test/{docId} {
      allow read, write: if true; // For connection testing
    }
  }
}
